# Mesh Gateway Settings
MESH_GATEWAY_URL=http://resilient-mesh-gateway:8090
MESH_GATEWAY_API_KEY=your_mesh_api_key_here

# Rapid Alert Platform Settings
RAPID_ALERT_URL=http://rapid-alert-platform:8080
RAPID_ALERT_CLIENT_ID=bridge_client
RAPID_ALERT_CLIENT_SECRET=super_secret_bridge_key

# IPAWS Configuration
IPAWS_SANDBOX=true
IPAWS_ENDPOINT=https://apps.fema.gov/IPAWSOPEN_EAS_SERVICE/rest

# Cache / Redis Settings (if externalized)
# REDIS_URL=redis://redis:6379/0
